{
    "welcomeFile": "/index.html",
    "authenticationMethod": "route",
    "sessionTimeout": 30,
    "routes": [
        {
            "source": "^/api/(.*)$",
            "target": "/api/$1",
            "destination": "backend",
            "authenticationType": "xsuaa",
            "scope": "$XSAPPNAME.AppAccess",
            "csrfProtection": false
        },
        {
            "source": "^/logout$",
            "target": "/logout",
            "destination": "backend",
            "authenticationType": "xsuaa"
        },
        {
            "source": "^/assets/(.*)$",
            "target": "/assets/$1",
            "localDir": "resources",
            "authenticationType": "xsuaa",
            "scope": "$XSAPPNAME.AppAccess",
            "csrfProtection": false
        },
        {
            "source": "^/.*$",
            "target": "/index.html",
            "localDir": "resources",
            "authenticationType": "xsuaa",
            "scope": "$XSAPPNAME.AppAccess",
            "csrfProtection": false
        }
    ]
}
