# Environment Configuration
# Copy this file to .env for local development

# Server Configuration
PORT=3001
NODE_ENV=development

# Database Configuration (Local Development)
# For local development, SQLite is used automatically
# No configuration needed

# Note: In Cloud Foundry deployment:
# - HANA connection is configured via bound services (VCAP_SERVICES)
# - XSUAA authentication is configured via bound services
# - PORT is assigned automatically by Cloud Foundry

# API Configuration (if needed)
# API_URL=http://localhost:3001

# Logging Configuration
LOG_LEVEL=info              # Options: error, warn, info, debug
LOG_SANITIZE=true           # Auto-redact sensitive data (passwords, tokens)
